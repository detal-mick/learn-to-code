    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Merriweather:wght@300;400&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --navy: #1a3a52;
            --navy-light: #2d5673;
            --navy-dark: #0f2635;
            --yellow: #f4b942;
            --yellow-light: #f7ca6d;
            --teal: #3bb5a3;
            --teal-light: #6ccaba;
            --teal-dark: #2a8c7e;
            --cream: #fef9f0;
            --white: #ffffff;
            --gray: #e8ede9;
            --text-dark: #2c3e50;
        }

        body {
            font-family: 'Merriweather', serif;
            background: linear-gradient(135deg, var(--cream) 0%, #f0f5f3 100%);
            color: var(--text-dark);
            line-height: 1.7;
            margin: 0;
            padding: 0;
            min-height: 100vh;
        }

        .container {
            max-width: 1100px;
            margin: 2rem auto;
            background: var(--white);
            border-radius: 24px;
            box-shadow: 0 20px 60px rgba(26, 58, 82, 0.12);
            overflow: hidden;
        }

        header {
            background: linear-gradient(135deg, var(--navy) 0%, var(--navy-light) 100%);
            color: var(--white);
            padding: 2rem 2.5rem 1.5rem;
            position: relative;
            overflow: hidden;
        }

        header::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -10%;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(59, 181, 163, 0.15) 0%, transparent 70%);
            border-radius: 50%;
        }

        h1 {
            font-family: 'DM Sans', sans-serif;
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 0.3rem;
            position: relative;
            z-index: 1;
        }

        .subtitle {
            font-family: 'DM Sans', sans-serif;
            font-size: 1rem;
            opacity: 0.9;
            font-weight: 400;
            position: relative;
            z-index: 1;
        }

        .badge {
            display: inline-block;
            background: var(--yellow);
            color: var(--navy);
            padding: 0.3rem 0.8rem;
            border-radius: 16px;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.85rem;
            font-weight: 500;
            margin-top: 0.8rem;
        }

        /* Tab Navigation */
        .tab-nav {
            background: var(--white);
            border-bottom: 2px solid var(--gray);
            display: flex;
            overflow-x: auto;
            overflow-y: hidden;
            white-space: nowrap;
            -webkit-overflow-scrolling: touch;
        }

        .tab-nav::-webkit-scrollbar {
            height: 4px;
        }

        .tab-nav::-webkit-scrollbar-track {
            background: var(--cream);
        }

        .tab-nav::-webkit-scrollbar-thumb {
            background: var(--teal);
            border-radius: 2px;
        }

        .tab-button {
            flex: 0 0 auto;
            padding: 1rem 1.5rem;
            background: transparent;
            border: none;
            border-bottom: 3px solid transparent;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.95rem;
            font-weight: 500;
            color: var(--text-dark);
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
        }

        .tab-button:hover {
            background: var(--cream);
            color: var(--navy);
        }

        .tab-button.active {
            color: var(--navy);
            border-bottom-color: var(--teal);
            background: linear-gradient(to bottom, var(--cream), var(--white));
        }

        .tab-button .tab-icon {
            margin-right: 0.5rem;
        }

        /* Tab Content */
        .tab-content {
            display: none;
            padding: 2.5rem;
            animation: fadeIn 0.4s ease-out;
        }

        .tab-content.active {
            display: block;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        h2 {
            font-family: 'DM Sans', sans-serif;
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--navy);
            margin-bottom: 1.5rem;
            padding-left: 1rem;
            border-left: 4px solid var(--teal);
        }

        h3 {
            font-family: 'DM Sans', sans-serif;
            font-size: 1.3rem;
            font-weight: 600;
            color: var(--navy-light);
            margin-bottom: 1rem;
            margin-top: 1.5rem;
        }

        h4 {
            font-family: 'DM Sans', sans-serif;
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--navy);
            margin-bottom: 0.5rem;
            margin-top: 1rem;
        }

        .info-box {
            background: linear-gradient(135deg, var(--teal-light) 0%, var(--teal) 100%);
            color: var(--white);
            padding: 1.5rem;
            border-radius: 16px;
            margin-bottom: 1.5rem;
            box-shadow: 0 4px 12px rgba(59, 181, 163, 0.2);
        }

        .info-box strong {
            font-family: 'DM Sans', sans-serif;
            font-weight: 600;
        }

        table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            margin: 1.5rem 0;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        }

        th {
            background: var(--navy);
            color: var(--white);
            padding: 1rem;
            text-align: left;
            font-family: 'DM Sans', sans-serif;
            font-weight: 600;
            font-size: 0.95rem;
        }

        td {
            padding: 1rem;
            border-bottom: 1px solid var(--gray);
            background: var(--white);
        }

        tr:last-child td {
            border-bottom: none;
        }

        tr:nth-child(even) td {
            background: #fafcfb;
        }

        .activity-card {
            background: var(--white);
            border: 2px solid var(--gray);
            border-radius: 16px;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
            transition: all 0.3s ease;
        }

        .activity-card:hover {
            border-color: var(--teal);
            box-shadow: 0 6px 20px rgba(59, 181, 163, 0.15);
        }

        .activity-number {
            display: inline-block;
            background: var(--yellow);
            color: var(--navy);
            width: 32px;
            height: 32px;
            border-radius: 50%;
            text-align: center;
            line-height: 32px;
            font-family: 'DM Sans', sans-serif;
            font-weight: 700;
            margin-right: 0.5rem;
        }

        input[type="text"], textarea {
            width: 100%;
            padding: 0.8rem 1rem;
            border: 2px solid var(--gray);
            border-radius: 10px;
            font-family: 'DM Sans', sans-serif;
            font-size: 1rem;
            margin: 0.5rem 0;
            transition: all 0.3s ease;
            background: var(--white);
        }

        input[type="text"]:focus, textarea:focus {
            outline: none;
            border-color: var(--teal);
            box-shadow: 0 0 0 3px rgba(59, 181, 163, 0.1);
        }

        textarea {
            min-height: 120px;
            resize: vertical;
            font-family: 'Merriweather', serif;
            line-height: 1.6;
        }

        .gap-fill-table {
            margin: 1.5rem 0;
        }

        .gap-fill-table input {
            background: var(--cream);
            border-color: var(--yellow);
            font-family: 'Merriweather', serif;
        }

        .prompt-box {
            background: linear-gradient(135deg, var(--navy) 0%, var(--navy-light) 100%);
            color: var(--white);
            padding: 1.5rem;
            border-radius: 16px;
            margin: 1.5rem 0;
            border-left: 6px solid var(--yellow);
        }

        .prompt-box p {
            font-size: 1.05rem;
            margin: 0;
            font-style: italic;
        }

        .note {
            background: var(--cream);
            border-left: 4px solid var(--yellow);
            padding: 1rem 1.5rem;
            margin: 1.5rem 0;
            border-radius: 8px;
            font-size: 0.95rem;
        }

        .note strong {
            font-family: 'DM Sans', sans-serif;
            color: var(--navy);
        }

        .sentence-box {
            background: var(--white);
            border: 2px dashed var(--teal-light);
            padding: 1rem;
            border-radius: 10px;
            margin: 0.5rem 0;
            font-style: italic;
            color: var(--text-dark);
        }

        footer {
            background: var(--gray);
            padding: 1.5rem 2.5rem;
            text-align: center;
            font-family: 'DM Sans', sans-serif;
            color: var(--navy);
            font-size: 0.9rem;
        }

        .skill-badge {
            display: inline-block;
            background: var(--teal-light);
            color: var(--navy);
            padding: 0.3rem 0.8rem;
            border-radius: 12px;
            font-size: 0.85rem;
            margin: 0.2rem;
            font-family: 'DM Sans', sans-serif;
        }

        @media (max-width: 768px) {
            .container {
                margin: 1rem;
                border-radius: 16px;
            }
            
            .tab-button {
                padding: 0.8rem 1rem;
                font-size: 0.85rem;
            }
            
            .tab-content {
                padding: 1.5rem;
            }
            
            h1 {
                font-size: 1.5rem;
            }
            
            h2 {
                font-size: 1.4rem;
            }
        }

        @media print {
            body {
                background: white;
            }
            .container {
                box-shadow: none;
            }
            .tab-nav {
                display: none;
            }
            .tab-content {
                display: block !important;
                page-break-after: always;
            }
        }
    </style>
</head>
